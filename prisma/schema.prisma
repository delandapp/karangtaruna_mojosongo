// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Di Prisma 7, url pindah ke prisma.config.ts / tidak perlu ditulis di sini jika pakai adapter
datasource db {
  provider = "postgresql" // Ganti 'postgresql' atau 'mysql' sesuai database yang dipakai
}

model m_level {
  id         Int    @id @default(autoincrement())
  nama_level String @unique // Contoh: "superuser", "admin", "anggota"

  users           m_user[]
  hak_akses_rules m_hak_akses_rule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model m_jabatan {
  id                Int     @id @default(autoincrement())
  nama_jabatan      String  @unique
  deskripsi_jabatan String?

  users           m_user[]
  hak_akses_rules m_hak_akses_rule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model m_user {
  id           Int  @id @default(autoincrement())
  m_jabatan_id Int?
  m_level_id   Int?

  nama_lengkap String
  username     String @unique
  password     String
  no_handphone String @unique

  rt            String
  rw            String
  alamat        String?
  jenis_kelamin String? // "L" atau "P"

  // Relasi
  jabatan m_jabatan? @relation(fields: [m_jabatan_id], references: [id], onDelete: SetNull)
  level   m_level?   @relation(fields: [m_level_id], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optimasi Index untuk pencarian relasi agar lebih cepat saat JOIN
  @@index([m_jabatan_id])
  @@index([m_level_id])
}

model m_kategori_brand {
  id                 Int     @id @default(autoincrement())
  nama_kategori      String  @unique
  deskripsi_kategori String?

  brands m_brand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model m_bidang_brand {
  id               Int     @id @default(autoincrement())
  nama_bidang      String  @unique
  deskripsi_bidang String?

  brands m_brand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model m_brand {
  id                  Int  @id @default(autoincrement())
  m_bidang_brand_id   Int?
  m_kategori_brand_id Int?

  nama_brand              String
  whatsapp_brand          String?
  email_brand             String?
  linkend_brand           String?
  instagram_brand         String?
  presentase_keberhasilan Float?
  perusahaan_induk        String?

  // Relasi
  bidang   m_bidang_brand?   @relation(fields: [m_bidang_brand_id], references: [id], onDelete: SetNull)
  kategori m_kategori_brand? @relation(fields: [m_kategori_brand_id], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optimasi Index
  @@index([m_bidang_brand_id])
  @@index([m_kategori_brand_id])
}

model m_hak_akses {
  id         Int    @id @default(autoincrement())
  nama_fitur String // "Create Kategori Brand"
  tipe_fitur String // "create", "update", "delete", "get_detail", "get_all"
  endpoint   String // "/api/sponsorship/kategori-brand"
  method     String // "POST", "GET", "PUT", "DELETE"

  is_all_level   Boolean @default(false)
  is_all_jabatan Boolean @default(false)

  rules m_hak_akses_rule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model m_hak_akses_rule {
  id             Int @id @default(autoincrement())
  m_hak_akses_id Int

  // Jika m_level_id ada namun m_jabatan_id null, berarti berlaku untuk level tersebut apapun jabatannya. 
  // Jika m_jabatan_id ada namun m_level_id null, berarti berlaku untuk jabatan tersebut apapun levelnya.
  // Jika keduanya ada, maka user harus memiliki level DAN jabatan tersebut (AND condition).
  m_level_id   Int?
  m_jabatan_id Int?

  hak_akses m_hak_akses @relation(fields: [m_hak_akses_id], references: [id], onDelete: Cascade)
  level     m_level?    @relation(fields: [m_level_id], references: [id], onDelete: Cascade)
  jabatan   m_jabatan?  @relation(fields: [m_jabatan_id], references: [id], onDelete: Cascade)

  @@index([m_hak_akses_id])
  @@index([m_level_id])
  @@index([m_jabatan_id])
}
