// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

// Di Prisma 7, url pindah ke prisma.config.ts / tidak perlu ditulis di sini jika pakai adapter
datasource db {
  provider = "postgresql" // Ganti 'postgresql' atau 'mysql' sesuai database yang dipakai
}
