model m_jenjang {
  id        BigInt      @id @default(autoincrement())
  nama      String      @unique @db.VarChar(100)
  deskripsi String?     @db.Text
  dibuat_pada DateTime    @default(now())
  diperbarui_pada DateTime    @updatedAt
  m_sekolah m_sekolah[]
  deleted   Boolean     @default(false)

  @@map("m_jenjang")
}
