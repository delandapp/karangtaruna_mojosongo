model Kecamatan {
    // 
    id           BigInt      @id @default(autoincrement())
    m_kota_id    BigInt?
    kode_wilayah String?     @unique
    nama         String
    createdAt    DateTime    @default(now())
    updatedAt    DateTime    @updatedAt
    Kota         Kota?       @relation(fields: [m_kota_id], references: [id])
    Kelurahan    Kelurahan[]
    Sekolah      Sekolah[]

    @@index([m_kota_id])
    @@map("m_kecamatan")
}
