model Kelurahan {
    id             BigInt     @id @default(autoincrement())
    m_kecamatan_id BigInt?
    kode_wilayah   String     @unique
    nama           String
    createdAt      DateTime   @default(now())
    updatedAt      DateTime   @updatedAt
    Kecamatan      Kecamatan? @relation(fields: [m_kecamatan_id], references: [id])
    Sekolah        Sekolah[]

    @@index([m_kecamatan_id])
    @@map("m_kelurahan")
}
