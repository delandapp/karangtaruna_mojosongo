// -----------------------------------------------------------------------------
// MASTER: KATEGORI BERITA
// Contoh: "Pengumuman", "Kegiatan", "Prestasi", "Sosial", "UMKM"
// -----------------------------------------------------------------------------
model m_kategori_berita {
  id            Int     @id @default(autoincrement())
  nama_kategori String  @unique
  slug_kategori String  @unique
  deskripsi     String?

  // Relasi
  berita berita[]

  dibuat_pada     DateTime @default(now())
  diperbarui_pada DateTime @updatedAt
}

// =============================================================================
// MODUL 7 — BERITA & PROMOSI
// =============================================================================

// -----------------------------------------------------------------------------
// BERITA / ARTIKEL
// -----------------------------------------------------------------------------
model berita {
  id                   Int  @id @default(autoincrement())
  event_id             Int?
  m_kategori_berita_id Int?
  penulis_id           Int

  judul            String
  slug             String    @unique
  konten           String    @db.Text
  thumbnail_url    String?
  status           String    @default("draft") // "draft" | "review" | "terbit" | "arsip"
  jumlah_tayang    Int       @default(0)
  dijadwalkan_pada DateTime?
  diterbitkan_pada DateTime?

  // Relasi
  event    event?             @relation(fields: [event_id], references: [id], onDelete: SetNull)
  kategori m_kategori_berita? @relation(fields: [m_kategori_berita_id], references: [id], onDelete: SetNull)
  penulis  m_user             @relation(fields: [penulis_id], references: [id])

  dibuat_pada     DateTime @default(now())
  diperbarui_pada DateTime @updatedAt

  @@index([event_id])
  @@index([m_kategori_berita_id])
  @@index([penulis_id])
  @@index([status])
  @@index([slug])
}

// -----------------------------------------------------------------------------
// KALENDER KONTEN PROMOSI
// Perencanaan & tracking posting media sosial per event
// -----------------------------------------------------------------------------
model kalender_konten {
  id               Int  @id @default(autoincrement())
  event_id         Int
  ditugaskan_ke_id Int?

  platform         String // "instagram" | "tiktok" | "facebook" | "whatsapp" | "youtube"
  jenis_konten     String // "feed" | "story" | "reels" | "broadcast" | "video"
  caption          String?   @db.Text
  url_media        String?
  hashtag          String?   @db.Text
  dijadwalkan_pada DateTime?
  diterbitkan_pada DateTime?
  reach            Int? // estimasi jangkauan
  engagement       Int? // jumlah interaksi
  status           String    @default("ide")
  // "ide" | "dibuat" | "review" | "terjadwal" | "tayang" | "batal"

  // Relasi
  event         event   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  ditugaskan_ke m_user? @relation(fields: [ditugaskan_ke_id], references: [id], onDelete: SetNull)

  dibuat_pada     DateTime @default(now())
  diperbarui_pada DateTime @updatedAt

  @@index([event_id])
  @@index([ditugaskan_ke_id])
  @@index([status])
  @@index([platform])
}
