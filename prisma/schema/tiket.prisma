// =============================================================================
// MODUL 2 — E-TIKET
// =============================================================================

// -----------------------------------------------------------------------------
// JENIS TIKET PER EVENT
// Contoh: "Early Bird", "Reguler", "VIP", "Family Pack"
// -----------------------------------------------------------------------------
model jenis_tiket {
  id       Int @id @default(autoincrement())
  event_id Int

  nama_tiket    String
  kategori_tiket String // "gratis" | "berbayar" | "early_bird" | "vip" | "bundling"
  harga         Decimal  @db.Decimal(12, 2) @default(0)
  kuota         Int
  terjual       Int      @default(0)
  keuntungan    Json?    // array string keuntungan tiket ini
  penjualan_buka DateTime
  penjualan_tutup DateTime
  is_aktif      Boolean  @default(true)

  // Relasi
  event   event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  order   tiket_order[]

  @@index([event_id])
  @@index([is_aktif])
}

// -----------------------------------------------------------------------------
// ORDER TIKET
// Satu order bisa membeli banyak tiket
// -----------------------------------------------------------------------------
model tiket_order {
  id             Int  @id @default(autoincrement())
  jenis_tiket_id Int
  user_id        Int? // null jika beli tanpa login

  nomor_order    String  @unique          // "ORD-20250801-0001"
  nama_pembeli   String
  email_pembeli  String
  hp_pembeli     String
  jumlah         Int
  total_harga    Decimal  @db.Decimal(12, 2)
  status_bayar   String   @default("menunggu")
  // "menunggu" | "lunas" | "gagal" | "dikembalikan"
  metode_bayar   String?  // "transfer" | "qris" | "gopay" | "ovo" | "dana"
  bukti_bayar_url String?
  dibayar_pada   DateTime?

  // Relasi
  jenis_tiket jenis_tiket    @relation(fields: [jenis_tiket_id], references: [id])
  user        m_user?        @relation(fields: [user_id],        references: [id], onDelete: SetNull)
  tiket_terbit tiket_terbit[]

  dibuat_pada    DateTime @default(now())
  diperbarui_pada DateTime @updatedAt

  @@index([jenis_tiket_id])
  @@index([user_id])
  @@index([status_bayar])
  @@index([nomor_order])
}

// -----------------------------------------------------------------------------
// TIKET TERBIT (Tiket Individual yang Diterbitkan)
// Setiap tiket punya QR Code unik untuk validasi hari-H
// -----------------------------------------------------------------------------
model tiket_terbit {
  id           Int @id @default(autoincrement())
  order_id     Int
  dicek_oleh_id Int?

  kode_tiket   String   @unique // "TKT-20250801-0001"
  qr_code      String   @db.Text // base64 / data QR
  nama_pemegang String
  status        String   @default("aktif") // "aktif" | "sudah_dipakai" | "dibatalkan"
  checkin_pada  DateTime?

  // Relasi
  order      tiket_order @relation(fields: [order_id],     references: [id], onDelete: Cascade)
  dicek_oleh m_user?     @relation("tiket_dicek_oleh",     fields: [dicek_oleh_id], references: [id], onDelete: SetNull)

  diterbitkan_pada DateTime @default(now())

  @@index([order_id])
  @@index([dicek_oleh_id])
  @@index([status])
}
